# ═══════════════════════════════════════════════════════════════════════
#  Trading Bot — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════════

# ── Broker Selection ──────────────────────────────────────────────────
# Currently only zerodha is active.
# To enable ICICI: change to icici and uncomment ICICI_* vars below.
BROKER=zerodha

# ── Zerodha Kite Connect ──────────────────────────────────────────────
ZERODHA_API_KEY=your_kite_api_key_here
ZERODHA_API_SECRET=your_kite_api_secret_here
ZERODHA_ACCESS_TOKEN=your_access_token_here
# Access token expires daily — generate at: https://kite.trade/connect/login

# ── ICICI Breeze (disabled — uncomment when ready) ────────────────────
# Steps: uncomment vars below, set BROKER=icici, and uncomment the
# ICICI blocks in config.py and brokers/__init__.py.
# ICICI_API_KEY=your_breeze_api_key_here
# ICICI_API_SECRET=your_breeze_api_secret_here
# ICICI_SESSION_TOKEN=your_breeze_session_token_here

# ── Telegram Alerts (disabled — uncomment when ready) ─────────────────
# Steps: uncomment vars below, then follow instructions in
# notifications/telegram_bot.py and main.py.
# Create a bot via @BotFather. Get chat_id by messaging @userinfobot.
# TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff-1234567890
# TELEGRAM_CHAT_ID=your_chat_id_here

# ── Trading Mode ──────────────────────────────────────────────────────
# Set PAPER_TRADE=true for simulation — NO real orders will be placed.
# Always start with paper trading!
PAPER_TRADE=true

# ── Capital & Risk ────────────────────────────────────────────────────
TRADING_CAPITAL=100000          # Total capital allocated (₹)
RISK_PER_TRADE_PCT=1.0          # Max % of capital to risk per trade
MAX_RISK_PER_TRADE_INR=5000     # Hard cap per trade regardless of % (₹)
MAX_DAILY_LOSS_INR=10000        # Bot stops trading if day loss hits this (₹)
MAX_DAILY_PROFIT_INR=15000      # Bot stops taking new trades after this (₹)
MAX_OPEN_POSITIONS=3            # Maximum simultaneous open trades
MAX_TRADES_PER_DAY=5            # Maximum trades per trading day

# ── Strategy Parameters ───────────────────────────────────────────────
STRATEGY=vwap_volume            # Active strategy module name
CANDLE_INTERVAL=5               # Candle timeframe in minutes (1/3/5/15)
TRADE_START_TIME=09:20          # Don't enter trades before this (IST)
TRADE_END_TIME=14:30            # Don't enter new trades after this (IST)
SQUAREOFF_TIME=15:15            # Force close all positions at this time (IST)

# ── Dashboard ─────────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
LOG_DIR=logs
LOG_RETENTION_DAYS=30
